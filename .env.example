# ── Elastic Drum — Environment Variables ──────────────────────────────────────
#
# Copy this file to .env and fill in the values.
# The .env file is NOT committed to git.
#
# ── MP3 Export Server (Railway) ───────────────────────────────────────────────
#
# Deploy the export-server/ folder to Railway:
#   1. cd export-server
#   2. railway login
#   3. railway init
#   4. railway up
#
# Then set this variable to the deployed URL:
#
VITE_MP3_SERVER_URL=https://your-export-server.up.railway.app
